# Cronicle Scheduler — environment variables
# Copy to .env and customize

# API key for skill scripts to authenticate with Cronicle (32-char hex)
# Generate: openssl rand -hex 16
CRONICLE_API_KEY=

# Shared secret for multi-server auth (auto-generated if empty)
CRONICLE_SECRET=

# Base URL for Cronicle (used in emails and UI links)
CRONICLE_BASE_URL=http://localhost:3012

# Web UI / API port
CRONICLE_PORT=3012

# Admin user password (default: admin)
CRONICLE_ADMIN_PASSWORD=admin
