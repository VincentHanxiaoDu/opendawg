{
  "name": "@opendog/discord-connector",
  "version": "0.1.0",
  "description": "Discord bot connector for OpenCode - intelligent coding assistance via Discord",
  "main": "dist/app.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "build:prod": "NODE_ENV=production node esbuild.config.js",
    "dev": "nodemon --watch src --ext ts --exec \"node esbuild.config.js && node dist/app.js\"",
    "start": "node dist/app.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["discord", "bot", "ai", "opencode", "coding-assistant"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "esbuild": "^0.25.11",
    "nodemon": "^3.1.10",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "@opencode-ai/sdk": "^1.0.224",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^17.2.2",
    "nanoid": "^5.1.6"
  }
}
