# Discord Bot Configuration

# Your Discord bot token from the Discord Developer Portal
DISCORD_BOT_TOKEN=

# Your Discord application ID from the Discord Developer Portal  
DISCORD_APP_ID=

# Comma-separated list of Discord user IDs allowed to use the bot
# Example: ALLOWED_USER_IDS=123456789012345678,987654321098765432
ALLOWED_USER_IDS=

# Admin user ID who receives notifications about unauthorized access attempts
ADMIN_USER_ID=

# Auto-kill the bot process on unauthorized access (true/false)
AUTO_KILL=false

# Message auto-delete timeout in milliseconds (default: 10000 = 10 seconds)
MESSAGE_DELETE_TIMEOUT=10000

# Temporary location for uploaded media files
MEDIA_TMP_LOCATION=/tmp/discordcoder_media

# OpenCode server URL (default: http://localhost:4096)
OPENCODE_SERVER_URL=http://localhost:4096

# Multiple OpenCode servers (format: url1|name1,url2|name2)
# OPENCODE_SERVER_URLS=http://server1:4096|Server1,http://server2:4096|Server2

# ─── Voice / TTS / STT Configuration ─────────────────────────────────────────
# Voice features are automatically enabled when a provider API key is present.
#
# Voice provider: "openai" (default) | "azure" | "google" (not yet implemented)
# VOICE_PROVIDER=openai
#
# TTS voice (default: alloy — options: alloy, echo, fable, onyx, nova, shimmer)
# VOICE_TTS_VOICE=alloy
#
# ── Option A: OpenAI ──────────────────────────────────────────────────────────
# VOICE_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# VOICE_STT_MODEL=whisper-1        # default: whisper-1
# VOICE_TTS_MODEL=tts-1            # default: tts-1
#
# ── Option B: Azure OpenAI ────────────────────────────────────────────────────
# VOICE_PROVIDER=azure
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-06-01   # default: 2024-06-01
# AZURE_VOICE_STT_DEPLOYMENT=whisper    # your Whisper deployment name (default: whisper)
# AZURE_VOICE_TTS_DEPLOYMENT=tts        # your TTS deployment name   (default: tts)
#
# Usage:
#   - Send an audio file attachment → auto-transcribed and sent to AI
#   - Use /join-voice to join your voice channel for real-time speech input
#   - Use /leave-voice to disconnect from the voice channel
#   - Use /tts [enabled:true/false] to toggle voice replies (default: off)
#
# Note: Real-time voice channel support requires @discordjs/voice and @discordjs/opus:
#   npm install @discordjs/voice @discordjs/opus
