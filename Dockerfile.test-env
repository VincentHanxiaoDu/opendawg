##############################################################################
# Dockerfile.test-env — Fully isolated Rocky Linux test environment
#
# Contains:
#   - opencode server (listening on :4097)
#   - opendawg CLI
#   - channel-telegram bot (test bot)
#
# The entrypoint reads config from /etc/opendawg/ (bind-mounted at runtime)
# and starts both opencode server + telegram bot as a single unit.
##############################################################################

FROM rockylinux:9-minimal

# ── System dependencies ──────────────────────────────────────────────────────
RUN microdnf install -y \
      python3 make gcc gcc-c++ \
      curl procps-ng ca-certificates findutils tar gzip \
    && microdnf clean all

# Node.js 22 (Rocky 9 default repo only has Node 16, too old)
RUN curl -fsSL https://rpm.nodesource.com/setup_22.x | bash - \
    && microdnf install -y nodejs \
    && microdnf clean all

# ripgrep (not in Rocky 9 minimal repos — install from GitHub release)
RUN curl -fsSL https://github.com/BurntSushi/ripgrep/releases/download/14.1.1/ripgrep-14.1.1-aarch64-unknown-linux-gnu.tar.gz \
    | tar xz -C /tmp \
    && cp /tmp/ripgrep-14.1.1-aarch64-unknown-linux-gnu/rg /usr/local/bin/rg \
    && chmod +x /usr/local/bin/rg \
    && rm -rf /tmp/ripgrep-*

# ── Install opencode globally ────────────────────────────────────────────────
RUN npm install -g opencode-ai@1.2.10

# ── Project setup ────────────────────────────────────────────────────────────
WORKDIR /opt/opendawg

# Copy and build channel-core
COPY packages/channel-core/ packages/channel-core/

# Copy CLI source
COPY cli/ cli/

# Root workspace config
COPY package.json tsconfig.json ./

# Copy all plugins (manifests + source)
COPY plugins/ plugins/

# Install and build everything
RUN npm install --legacy-peer-deps \
    && cd packages/channel-core && npm run build && cd ../.. \
    && cd cli && npm run build && cd .. \
    && cd plugins/channel-telegram \
    && npm install --legacy-peer-deps \
    && npm rebuild better-sqlite3 \
    && npm run build:prod \
    && cd ../..

# Make opendawg CLI globally available
RUN ln -sf /opt/opendawg/cli/dist/index.js /usr/local/bin/opendawg \
    && chmod +x /opt/opendawg/cli/dist/index.js

# ── Config injection point ───────────────────────────────────────────────────
# The deploy script bind-mounts config files here at runtime:
#   /etc/opendawg/opendawg.yaml    → project config
#   /etc/opendawg/opencode/        → .opencode dir (skills, commands, plugins)
#   /etc/opendawg/agents.md        → AGENTS.md
RUN mkdir -p /etc/opendawg/opencode /data

# ── Entrypoint ───────────────────────────────────────────────────────────────
COPY scripts/test-env-entrypoint.sh /opt/opendawg/entrypoint.sh
RUN chmod +x /opt/opendawg/entrypoint.sh

# ── Ports & health ──────────────────────────────────────────────────────────
EXPOSE 4097

HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
    CMD pgrep -f "opencode.*serve" > /dev/null && pgrep -f "node.*dist/app" > /dev/null || exit 1

ENTRYPOINT ["/opt/opendawg/entrypoint.sh"]
