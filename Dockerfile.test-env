##############################################################################
# Dockerfile.test-env — Independent test environment for opendawg
#
# Builds the opendawg CLI, channel-core, and telegram plugin inside a
# single container. Configures and starts the test bot on container startup.
#
# Build:  docker build -f Dockerfile.test-env -t opendawg-test-env .
# Run:    docker run -d --name opendawg-test \
#           -e TEST_BOT_TOKEN=<token> \
#           -e TEST_USER_ID=<id> \
#           -e TEST_ADMIN_ID=<id> \
#           opendawg-test-env
##############################################################################

FROM node:22-slim

# Build tools for native addons (node-pty, better-sqlite3)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ curl procps ca-certificates ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/opendawg

# Copy and build channel-core
COPY packages/channel-core/ packages/channel-core/

# Copy and build CLI
COPY cli/ cli/
COPY package.json tsconfig.json ./

# Copy plugin manifests and source (needed by CLI for discovery)
COPY plugins/ plugins/

# Copy entrypoint
COPY scripts/test-env-entrypoint.sh /opt/opendawg/entrypoint.sh
RUN chmod +x /opt/opendawg/entrypoint.sh

# Install and build everything
RUN npm install --legacy-peer-deps \
    && cd packages/channel-core && npm run build && cd ../.. \
    && cd cli && npm run build && cd .. \
    && cd plugins/channel-telegram \
    && npm install --legacy-peer-deps \
    && npm rebuild better-sqlite3 \
    && npm run build:prod \
    && cd ../..

# Make the CLI globally available
RUN ln -sf /opt/opendawg/cli/dist/index.js /usr/local/bin/opendawg \
    && chmod +x /opt/opendawg/cli/dist/index.js

# Health check
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
    CMD pgrep -f "node.*dist/app" || exit 1

ENV TEST_BOT_TOKEN=""
ENV TEST_USER_ID=""
ENV TEST_ADMIN_ID=""
ENV TEST_SERVER_URL="http://host.docker.internal:4096"

ENTRYPOINT ["/opt/opendawg/entrypoint.sh"]
