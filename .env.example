# === Required: Azure OpenAI ===

# Azure OpenAI API key — used by Graphiti for LLM and embedding operations
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

# Azure OpenAI endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure OpenAI LLM deployment name
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Azure OpenAI API version
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Azure OpenAI embedding deployment name
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-large

# Azure OpenAI embeddings endpoint (same as main endpoint if using same resource)
AZURE_OPENAI_EMBEDDINGS_ENDPOINT=https://your-resource.openai.azure.com/

# === Required: Config-CLI ===

# Config-CLI master token — used to encrypt/decrypt vault secrets
# Generate with: openssl rand -hex 32
CONFIG_CLI_TOKEN=your-master-token-here

# === Optional: Neo4j ===

# Neo4j password (default: graphiti)
NEO4J_PASSWORD=graphiti

# === Optional: Ports ===

# Graphiti MCP server port (default: 8000)
GRAPHITI_PORT=8000

# Neo4j browser port (default: 7474)
NEO4J_HTTP_PORT=7474

# Neo4j bolt port (default: 7687)
NEO4J_BOLT_PORT=7687

# Config-CLI HTTP server port (default: 9100)
CONFIG_CLI_PORT=9100

# === Optional: OpenCode Server ===

# HTTP Basic Auth password for opencode serve (leave empty to disable)
OPENCODE_SERVER_PASSWORD=

# HTTP Basic Auth username (default: opencode)
# OPENCODE_SERVER_USERNAME=opencode

# === Optional: Channel — Telegram ===

# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot
TELEGRAM_ALLOWED_USER_IDS=

# Admin user ID (receives admin-level notifications)
ADMIN_USER_ID=

# Auto-delete bot messages after N seconds (0 = disabled)
TELEGRAM_MESSAGE_DELETE_TIMEOUT=0

# OpenCode server URL(s)
#
# OPENCODE_SERVER_URLS (recommended): comma-separated list of servers.
# Format: "url|name,url2|name2" — name is optional (defaults to host:port).
# Example (multiple servers):
#   OPENCODE_SERVER_URLS=http://localhost:4096|Local,http://192.168.1.100:4096|Remote Dev
# Example (single server):
#   OPENCODE_SERVER_URLS=http://localhost:4096|Local
#
# With network_mode: "host" (Linux), localhost reaches the host machine directly.
# On macOS (Docker Desktop), the container runs in a VM — use host.docker.internal:
#   OPENCODE_SERVER_URLS=http://host.docker.internal:4096|Local
#
OPENCODE_SERVER_URLS=

# Legacy single-server variable (used if OPENCODE_SERVER_URLS is not set)
# On Linux with host networking: localhost works directly
# On macOS with Docker Desktop: use host.docker.internal
OPENCODE_SERVER_URL=http://localhost:4096
