# === Required: Azure OpenAI ===

# Azure OpenAI API key — used by Graphiti for LLM and embedding operations
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

# Azure OpenAI endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure OpenAI LLM deployment name
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Azure OpenAI API version
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Azure OpenAI embedding deployment name
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-large

# Azure OpenAI embeddings endpoint (same as main endpoint if using same resource)
AZURE_OPENAI_EMBEDDINGS_ENDPOINT=https://your-resource.openai.azure.com/

# === Required: Config-CLI ===

# Config-CLI master token — used to encrypt/decrypt vault secrets
# Generate with: openssl rand -hex 32
CONFIG_CLI_TOKEN=your-master-token-here

# === Optional: Neo4j ===

# Neo4j password (default: graphiti)
NEO4J_PASSWORD=graphiti

# === Optional: Ports ===

# Graphiti MCP server port (default: 8000)
GRAPHITI_PORT=8000

# Neo4j browser port (default: 7474)
NEO4J_HTTP_PORT=7474

# Neo4j bolt port (default: 7687)
NEO4J_BOLT_PORT=7687

# Config-CLI HTTP server port (default: 9100)
CONFIG_CLI_PORT=9100

# === Optional: OpenCode Server ===

# HTTP Basic Auth password for opencode serve (leave empty to disable)
OPENCODE_SERVER_PASSWORD=

# HTTP Basic Auth username (default: opencode)
# OPENCODE_SERVER_USERNAME=opencode
